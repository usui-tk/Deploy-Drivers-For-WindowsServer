# =============================================================================
# Deploy-Drivers-For-WindowsServer .gitignore
# =============================================================================

# ----- Script runtime artefacts (never commit) -------------------------------
# These are generated by the PowerShell scripts and contain machine-specific
# data (cert thumbprints, hardware fingerprints, etc.)
#
# r58+ / r26+ / r8+ / r2+: workspaces are now relocated under
# C:\Temp\Workspace_*. The script auto-creates C:\Temp on demand. The
# legacy paths (C:\AMD-{Chipset,Graphics,NPU}-WS, C:\MSBthPan-WS) are
# kept here so a clone that still has those left-over directories on
# disk also stays clean.
C:/Temp/Workspace_AMD-Chipset/
C:/Temp/Workspace_AMD-Graphics/
C:/Temp/Workspace_AMD-NPU/
C:/Temp/Workspace_Microsoft-BthPan/
C:/Temp/Workspace_*/
C:/AMD-Chipset-WS/
C:/AMD-Graphics-WS/
C:/AMD-NPU-WS/
C:/MSBthPan-WS/
*.pfx
*.cer
*.cat
*.snk
inf_inventory.csv
inf_inventory_report.txt

# ----- Console / run logs (never commit) -------------------------------------
# Any *.log file is considered a per-run artifact. The recommended
# filename convention from r58+ / r26+ / r8+ / r2+ is:
#   C:\Temp\<scripttag>_<Action>_<yyyyMMdd-HHmmss>.log
# (e.g. amd-chipset_PrepareVerify_20260517-143022.log).
*.log

# ----- Python tool artefacts -------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# ----- IDE / editor ----------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ----- Build / package -------------------------------------------------------
build/
dist/
*.egg-info/

# ----- AMD installer downloads (large binaries, never commit) ----------------
amd_chipset_software_*.exe
whql-amd-software-*.exe
non-whql-amd-software-*.exe

# AMD NPU driver ZIPs (Ryzen AI Software bundles, EULA-gated, never redistribute)
NPU_RAI*.zip
NPU_RAI*_WHQL/
ryzen-ai-*.exe

# ----- Sensitive / personal --------------------------------------------------
*.key
*.pem
*.p12
*.password
secrets.json
.env
.env.local
